DJANGO_SETTINGS_MODULE=autrifix.settings.development
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Neon (recommended): paste the connection string from Neon → Connection details → URI
# (includes sslmode=require). When set, POSTGRES_* below are ignored.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Local PostgreSQL / Docker Compose (only if DATABASE_URL is unset)
POSTGRES_DB=autrifix
POSTGRES_USER=autrifix
POSTGRES_PASSWORD=autrifix 
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_URL=redis://127.0.0.1:6379/0
CHANNEL_REDIS_URL=redis://127.0.0.1:6379/3
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
# Namespace all Redis keys for this app (cache, Celery, Channels) when sharing one Redis instance
REDIS_KEY_PREFIX=autrifix
# Development toggle:
# - false => no local Redis required (uses in-memory cache/channels)
# - true  => use Redis endpoints above
USE_REDIS=false

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Phone OTP (SMS) — codes stored hashed; default TTL 300s; max sends per phone per hour
OTP_TTL_SECONDS=300
OTP_SEND_MAX_PER_HOUR=5
SMS_PROVIDER=console
# Twilio (only when SMS_PROVIDER=twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Termii (only when SMS_PROVIDER=termii)
# TERMII_API_KEY=
# TERMII_SENDER_ID=AutriFix
# TERMII_CHANNEL=generic
# TERMII_SMS_TYPE=plain

# Optional Cloudinary (omit to use local MEDIA_ROOT)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
