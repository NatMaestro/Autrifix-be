# Production — copy to your host / secret manager (do not commit real values)
DJANGO_SETTINGS_MODULE=autrifix.settings.production
SECRET_KEY=
ALLOWED_HOSTS=api.yourdomain.com
DEBUG=False

# Neon: paste from dashboard (Connection details → URI). Pooled endpoint is fine for web workers.
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# If you do not use DATABASE_URL, set discrete vars instead:
# POSTGRES_DB=autrifix
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_HOST=
# POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60
POSTGRES_CONNECT_TIMEOUT=10

REDIS_URL=
CHANNEL_REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
# Namespace Redis keys when sharing one Redis/Key-Value instance across apps
REDIS_KEY_PREFIX=autrifix

# Phone OTP (SMS)
OTP_TTL_SECONDS=300
OTP_SEND_MAX_PER_HOUR=5
SMS_PROVIDER=console
# Twilio (only when SMS_PROVIDER=twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# Termii (only when SMS_PROVIDER=termii)
# TERMII_API_KEY=
# TERMII_SENDER_ID=
# TERMII_CHANNEL=generic
# TERMII_SMS_TYPE=plain

CORS_ALLOWED_ORIGINS=https://yourdomain.com
CSRF_TRUSTED_ORIGINS=https://api.yourdomain.com,https://yourdomain.com
CORS_ALLOW_CREDENTIALS=true

USE_TLS=true
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000

# Optional Cloudinary
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
